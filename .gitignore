# ============================================
# Fund Selector — .gitignore
# ===========================================

# --- 敏感信息（永远不要上传）---
.claude/settings.local.json
.mcp.json
*.pem
*.key
.env
.env.*
secrets/

# --- 个人持仓数据 ---
portfolio.json
fund_screening*.xlsx

# --- 生成的报告文件 ---
fund-reports/

# --- 个人工作笔记（本地开发用）---
.planning/
task_plan.md
progress.md
findings.md
skill-design-brief.md
iteration-3/

# --- 个人独立脚本（非 skill 部分）---
fund_selector.py
weekly_report.py
import_alipay.py
generate_corrected_excel.py
pipeline_runner.py
columns.txt

# --- 旧版备份 ---
.claude/skills/fund-recommend/iteration-2-backup/
.claude/skills/fund-recommend/iteration-3-backup/

# --- 一次性审计报告（已过时）---
.claude/skills/fund-selector/reports/SKILL_AUDIT_REPORT.md

# --- 嵌套 git 仓库 / 外部依赖 ---
FinanceAgent/
ai-berkshire/
cn-financial-mcp/
cn-financial-services-plugins/
cn-mutual-fund/
config/
registry/

# --- Python 缓存 ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# --- 虚拟环境 ---
venv/
.venv/
env/

# --- IDE 配置 ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# --- 系统文件 ---
.DS_Store
Thumbs.db
desktop.ini

# --- 日志文件 ---
*.log
*_stderr.txt
*_stdout.json
C:Users*

# --- screenpipe / 屏幕录制调试输出 ---
_screen_*
screen_*.txt
screen_*.json

# --- Windows 设备名误生成的文件 ---
nul
con
prn
aux

# --- 临时文件 ---
*.tmp
*.bak
*.swp
*~
