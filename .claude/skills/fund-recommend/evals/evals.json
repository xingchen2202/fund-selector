{
  "skill": "fund-recommend",
  "version": "iteration-3",
  "description": "P1+P2 修复后的自动化断言",
  "evals": [
    {
      "id": "B1-scale-filter",
      "description": "P1：规模筛选必须排除规模<2亿的基金",
      "prompt": "运行/fund:recommend，检查最终报告",
      "assertions": [
        {
          "type": "not_contains",
          "value": "44.81万",
          "description": "报告中不应出现44.81万规模的基金（024120）"
        },
        {
          "type": "not_contains",
          "value": "3877.78万",
          "description": "报告中不应出现3877万规模的基金（002214）"
        },
        {
          "type": "not_contains",
          "value": "744.35万",
          "description": "报告中不应出现744万规模的基金（020362）"
        },
        {
          "type": "contains",
          "value": "规模",
          "description": "报告应包含规模信息或排除日志"
        }
      ]
    },
    {
      "id": "B2-scale-exclude-log",
      "description": "P1：排除日志应出现在 stderr 输出中",
      "prompt": "运行 screen_candidates.py，检查 stderr 输出",
      "assertions": [
        {
          "type": "stderr_contains",
          "value": "EXCLUDE",
          "description": "stderr 应包含 EXCLUDE 日志行"
        },
        {
          "type": "stderr_contains",
          "value": "2亿",
          "description": "排除原因应提及2亿阈值"
        }
      ]
    },
    {
      "id": "B3-scale-threshold-config",
      "description": "P1：规模阈值应可配置",
      "prompt": "检查 screen_candidates.py 源码",
      "assertions": [
        {
          "type": "source_contains",
          "value": "SCALE_THRESHOLD_WAN",
          "description": "源码应定义 SCALE_THRESHOLD_WAN 常量"
        },
        {
          "type": "source_contains",
          "value": "20000",
          "description": "阈值应为 20000（万元）"
        }
      ]
    },
    {
      "id": "B4-news-chinese",
      "description": "P2：新闻搜索词必须全部为中文",
      "prompt": "检查 search_news.py 源码中的 SECTOR_QUERIES",
      "assertions": [
        {
          "type": "source_not_contains",
          "value": "NASDAQ US tech",
          "description": "搜索词不应包含英文 'NASDAQ US tech'"
        },
        {
          "type": "source_not_contains",
          "value": "gold price outlook",
          "description": "搜索词不应包含英文 'gold price outlook'"
        },
        {
          "type": "source_not_contains",
          "value": "Hang Seng tech",
          "description": "搜索词不应包含英文 'Hang Seng tech'"
        },
        {
          "type": "source_contains",
          "value": "美国纳斯达克",
          "description": "纳斯达克板块应使用中文搜索词"
        },
        {
          "type": "source_contains",
          "value": "黄金市场",
          "description": "黄金板块应使用中文搜索词"
        }
      ]
    },
    {
      "id": "B5-news-days-param",
      "description": "P2：Tavily搜索必须传入 days=7",
      "prompt": "检查 search_news.py 源码中 tavily 调用",
      "assertions": [
        {
          "type": "source_contains",
          "value": "days=7",
          "description": "Tavily搜索调用必须包含 days=7 参数"
        }
      ]
    },
    {
      "id": "B6-news-time-check",
      "description": "P2：输出必须包含发布时间检查",
      "prompt": "检查 search_news.py 源码",
      "assertions": [
        {
          "type": "source_contains",
          "value": "published_date",
          "description": "输出应包含 published_date 字段"
        },
        {
          "type": "source_contains",
          "value": "时间超期",
          "description": "应标注超期新闻"
        }
      ]
    }
  ]
}
