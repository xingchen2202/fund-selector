{
  "skill": "fund-recommend",
  "version": "iteration-3",
  "description": "P1+P2 修复后的自动化断言",
  "evals": [
    {
      "id": "B1-scale-filter",
      "description": "P1：规模筛选必须排除规模<2亿的基金",
      "prompt": "运行/fund:recommend，检查最终报告",
      "assertions": [
        {
          "type": "not_contains",
          "value": "44.81万",
          "description": "报告中不应出现44.81万规模的基金（024120）"
        },
        {
          "type": "not_contains",
          "value": "3877.78万",
          "description": "报告中不应出现3877万规模的基金（002214）"
        },
        {
          "type": "not_contains",
          "value": "744.35万",
          "description": "报告中不应出现744万规模的基金（020362）"
        },
        {
          "type": "contains",
          "value": "规模",
          "description": "报告应包含规模信息或排除日志"
        }
      ]
    },
    {
      "id": "B2-scale-exclude-log",
      "description": "P1：排除日志应出现在 stderr 输出中",
      "prompt": "运行 screen_candidates.py，检查 stderr 输出",
      "assertions": [
        {
          "type": "stderr_contains",
          "value": "EXCLUDE",
          "description": "stderr 应包含 EXCLUDE 日志行"
        },
        {
          "type": "stderr_contains",
          "value": "20000",
          "description": "排除原因应提及20000万阈值"
        }
      ]
    },
    {
      "id": "B3-scale-threshold-config",
      "description": "P1：规模阈值应可配置",
      "prompt": "检查 screen_candidates.py 源码",
      "assertions": [
        {
          "type": "source_contains",
          "value": "SCALE_THRESHOLD_WAN",
          "description": "源码应定义 SCALE_THRESHOLD_WAN 常量"
        },
        {
          "type": "source_contains",
          "value": "20000",
          "description": "阈值应为 20000（万元）"
        }
      ]
    },
    {
      "id": "B4-news-chinese",
      "description": "P2：新闻搜索词必须全部为中文",
      "prompt": "检查 search_news.py 源码中的 SECTOR_QUERIES",
      "assertions": [
        {
          "type": "source_not_contains",
          "value": "NASDAQ US tech",
          "description": "搜索词不应包含英文 NASDAQ US tech"
        },
        {
          "type": "source_not_contains",
          "value": "gold price outlook",
          "description": "搜索词不应包含英文 gold price outlook"
        },
        {
          "type": "source_not_contains",
          "value": "Hang Seng tech",
          "description": "搜索词不应包含英文 Hang Seng tech"
        },
        {
          "type": "source_contains",
          "value": "纳斯达克",
          "description": "纳斯达克板块应使用中文搜索词"
        },
        {
          "type": "source_contains",
          "value": "黄金",
          "description": "黄金板块应使用中文搜索词"
        }
      ]
    },
    {
      "id": "B5-news-days-param",
      "description": "P2：Tavily搜索必须传入 days=7",
      "prompt": "检查 search_news.py 源码中 tavily 调用",
      "assertions": [
        {
          "type": "source_contains",
          "value": "days",
          "description": "Tavily搜索调用必须传入 days 参数"
        },
        {
          "type": "source_contains",
          "value": "7",
          "description": "days 参数值应为 7"
        }
      ]
    },
    {
      "id": "B6-news-time-check",
      "description": "P2：输出必须包含发布时间检查",
      "prompt": "检查 search_news.py 源码",
      "assertions": [
        {
          "type": "source_contains",
          "value": "published_date",
          "description": "输出应包含 published_date 字段"
        },
        {
          "type": "source_contains",
          "value": "days",
          "description": "应限制搜索时间范围"
        }
      ]
    },
    {
      "id": "B2-chinese-news",
      "description": "P2：新闻必须为中文内容，且在7天内",
      "prompt": "运行/fund:report或/fund:recommend，检查新闻板块",
      "assertions": [
        {
          "type": "not_contains",
          "value": "As of June 2026",
          "description": "报告中不应出现英文新闻开头"
        },
        {
          "type": "not_contains",
          "value": "Goldman Sachs predicts",
          "description": "报告中不应出现英文机构名预测语"
        },
        {
          "type": "contains",
          "value": "新闻背景",
          "description": "报告应包含新闻背景板块"
        }
      ]
    },
    {
      "id": "B3-data-flow",
      "description": "P3：推荐报告必须包含完整的VaR和新闻数据",
      "prompt": "运行/fund:recommend，检查报告正文",
      "assertions": [
        {
          "type": "not_contains",
          "value": "新闻：无",
          "description": "报告中不应出现「新闻：无」"
        },
        {
          "type": "not_contains",
          "value": "VaR影响：无",
          "description": "报告中不应出现「VaR影响：无」"
        },
        {
          "type": "contains",
          "value": "利多",
          "description": "报告应包含利多新闻"
        },
        {
          "type": "contains",
          "value": "利空",
          "description": "报告应包含利空新闻"
        },
        {
          "type": "contains",
          "value": "VaR",
          "description": "报告应包含VaR数值"
        }
      ]
    },
    {
      "id": "B4-return-label",
      "description": "P4：成立不满3年的基金不应标注近3年",
      "prompt": "验证recommend报告中020362的收益标注",
      "assertions": [
        {
          "type": "not_contains",
          "value": "近3年：+51.71%",
          "description": "020362不应标注近3年收益"
        },
        {
          "type": "contains",
          "value": "成立以来",
          "description": "成立不满3年的基金应标注成立以来"
        }
      ]
    },
    {
      "id": "B5-mcp-data-flow",
      "description": "P5：推荐报告不得出现待补充占位符",
      "prompt": "运行/fund:recommend，检查报告数据完整性",
      "assertions": [
        {
          "type": "not_contains",
          "value": "待补充",
          "description": "报告中不应出现任何'待补充'占位符"
        },
        {
          "type": "not_contains",
          "value": "周期判断：未知",
          "description": "宏观周期判断不应为未知"
        },
        {
          "type": "not_contains",
          "value": "总市值：N/A",
          "description": "总市值不应为N/A"
        },
        {
          "type": "contains",
          "value": "近1年",
          "description": "报告应包含近1年收益数据"
        },
        {
          "type": "contains",
          "value": "经理",
          "description": "报告应包含基金经理信息"
        }
      ]
    },
    {
      "id": "B6-chinese-news",
      "description": "P6：新闻必须为中文内容，且来自中文数据源",
      "prompt": "运行/fund:report，检查板块新闻摘要",
      "assertions": [
        {
          "type": "not_contains",
          "value": "China's central bank announced",
          "description": "不应出现英文新闻内容"
        },
        {
          "type": "not_contains",
          "value": "As of June 2026",
          "description": "不应出现英文时间标注"
        },
        {
          "type": "not_contains",
          "value": "Goldman Sachs",
          "description": "不应出现英文机构名"
        },
        {
          "type": "contains",
          "value": "银行",
          "description": "银行板块新闻应包含中文'银行'关键词"
        }
      ]
    }
  ]
}