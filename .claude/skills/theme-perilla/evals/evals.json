      "assertions": [
        {"type": "contains", "value": "细分市占率"},
        {"type": "contains", "value": "毛利率"},
        {"type": "contains", "value": "机构持仓"},
        {"type": "contains", "value": "技术壁垒"},
        {"type": "contains", "value": "产能约束"}
      ]
    },
    {
      "id": "E03-scoring-threshold",
      "description": "评分阈值应正确",
