        {"type": "file_exists", "value": "scripts/perilla_scorer.py"},
        {"type": "file_exists", "value": "scripts/industry_chain.py"}
      ]
    },
    {
      "id": "E06-output-format",
      "description": "报告应包含紫苏叶评级输出",
      "assertions": [
        {"type": "contains", "value": "紫苏叶指数"},
        {"type": "contains", "value": "瓶颈地图"}
      ]
    }
