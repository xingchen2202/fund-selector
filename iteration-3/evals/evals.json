{
  "skill": "fund-recommend",
  "version": "iteration-3",
  "description": "P5 修复后的自动化断言：MCP调用职责分离",
  "evals": [
    {
      "id": "C1-mcp-macro-data",
      "description": "P5：宏观数据必须从MCP获取，不能全为N/A或未知",
      "prompt": "运行/fund:recommend，检查报告中的宏观环境章节",
      "assertions": [
        {
          "type": "not_contains",
          "value": "周期判断：未知（置信度：N/A）",
          "description": "宏观周期不能全为未知"
        },
        {
          "type": "not_contains",
          "value": "总市值：N/A 元",
          "description": "总市值不能为N/A"
        },
        {
          "type": "not_contains",
          "value": "总市值：N/A",
          "description": "总市值字段必须有具体数值"
        }
      ]
    },
    {
      "id": "C2-mcp-fund-data",
      "description": "P5：基金数据必须从MCP获取，经理/费率/收益不能全为待补充",
      "prompt": "运行/fund:recommend，检查报告中候选基金的数据层",
      "assertions": [
        {
          "type": "not_contains",
          "value": "经理：待补充",
          "description": "经理字段不能为待补充"
        },
        {
          "type": "not_contains",
          "value": "总费率：待补充",
          "description": "费率字段不能为待补充"
        },
        {
          "type": "not_contains",
          "value": "近1年：待补充",
          "description": "近1年收益不能为待补充"
        },
        {
          "type": "not_contains",
          "value": "近3年：待补充",
          "description": "近3年收益不能为待补充"
        },
        {
          "type": "not_contains",
          "value": "最大回撤：待补充",
          "description": "最大回撤不能为待补充"
        },
        {
          "type": "contains",
          "value": "经理：",
          "description": "报告应包含经理信息"
        },
        {
          "type": "contains",
          "value": "总费率：",
          "description": "报告应包含费率信息"
        }
      ]
    },
    {
      "id": "C3-pipeline-step-files-exist",
      "description": "P5：step1 和 step3 文件必须由 Claude MCP 调用生成",
      "prompt": "运行/fund:recommend 后检查 fund-reports/ 目录中的 pipeline 文件",
      "assertions": [
        {
          "type": "file_exists",
          "value": "_pipeline_step1_macro.json",
          "description": "step1 宏观数据文件必须存在"
        },
        {
          "type": "file_exists",
          "value": "_pipeline_step3_funds.json",
          "description": "step3 基金验证文件必须存在"
        }
      ]
    },
    {
      "id": "C4-mcp-data-in-pipeline",
      "description": "P5：step1 文件必须包含实际MCP数据（非空模板）",
      "prompt": "读取 _pipeline_step1_macro.json 检查内容",
      "assertions": [
        {
          "type": "file_contains",
          "value": "cycle_judgment",
          "description": "step1 文件必须包含 cycle_judgment 字段"
        },
        {
          "type": "file_contains",
          "value": "available_indicators",
          "description": "step1 文件必须包含 available_indicators 字段"
        }
      ]
    },
    {
      "id": "C5-fund-data-in-pipeline",
      "description": "P5：step3 文件必须包含实际基金数据（非空）",
      "prompt": "读取 _pipeline_step3_funds.json 检查内容",
      "assertions": [
        {
          "type": "file_contains",
          "value": "verified",
          "description": "step3 文件必须包含 verified 数组"
        },
        {
          "type": "file_contains",
          "value": "manager",
          "description": "verified 数组中应包含 manager 字段"
        },
        {
          "type": "file_contains",
          "value": "return_1y",
          "description": "verified 数组中应包含 return_1y 字段"
        }
      ]
    },
    {
      "id": "B1-scale-filter",
      "description": "P1：规模筛选必须排除规模<2亿的基金",
      "prompt": "运行/fund:recommend，检查最终报告",
      "assertions": [
        {
          "type": "not_contains",
          "value": "44.81万",
          "description": "报告中不应出现44.81万规模的基金（024120）"
        },
        {
          "type": "not_contains",
          "value": "3877.78万",
          "description": "报告中不应出现3877万规模的基金（002214）"
        },
        {
          "type": "not_contains",
          "value": "744.35万",
          "description": "报告中不应出现744万规模的基金（020362）"
        },
        {
          "type": "contains",
          "value": "规模",
          "description": "报告应包含规模信息或排除日志"
        }
      ]
    },
    {
      "id": "B4-news-chinese",
      "description": "P2：新闻搜索词必须全部为中文",
      "prompt": "检查 search_news.py 源码中的 SECTOR_QUERIES",
      "assertions": [
        {
          "type": "source_not_contains",
          "value": "NASDAQ US tech",
          "description": "搜索词不应包含英文 NASDAQ US tech"
        },
        {
          "type": "source_not_contains",
          "value": "gold price outlook",
          "description": "搜索词不应包含英文 gold price outlook"
        },
        {
          "type": "source_contains",
          "value": "纳斯达克",
          "description": "纳斯达克板块应使用中文搜索词"
        },
        {
          "type": "source_contains",
          "value": "黄金",
          "description": "黄金板块应使用中文搜索词"
        }
      ]
    },
    {
      "id": "B4-return-label",
      "description": "P4：成立不满3年的基金不应标注近3年",
      "prompt": "验证recommend报告中成立不满3年的基金的收益标注",
      "assertions": [
        {
          "type": "not_contains",
          "value": "近3年：+51.71%",
          "description": "020362不应标注近3年收益"
        },
        {
          "type": "contains",
          "value": "成立以来",
          "description": "成立不满3年的基金应标注成立以来"
        }
      ]
    }
  ]
}
